{
  "schema": 2,
  "permissions": [
    "chat.write_message",
    "tools.invoke"
  ],
  "required_executas": [
    {
      "tool_id": "bundled:llm-via-executa",
      "min_version": "0.1.0",
      "version": "latest"
    }
  ],
  "optional_executas": [],
  "system_prompt_addendum": "The user has the LLM Demo app open. It can run an LLM completion either directly (anna.llm.complete) or via the bundled llm-via-executa Executa (which calls sampling/createMessage back to the host LLM). It also exercises anna.agent.session. You do not need to summon any windows.",
  "tags": ["demo", "llm", "agent", "executa", "sampling"],
  "ui": {
    "bundle": {
      "format": "static-spa",
      "entry": "index.html",
      "external_origins": []
    },
    "views": [
      {
        "name": "main",
        "title": "LLM Demo",
        "default": true,
        "entry": "index.html",
        "min_size": { "w": 460, "h": 600 },
        "default_size": { "w": 600, "h": 780 },
        "resizable": true,
        "movable": true,
        "single_instance": true
      }
    ],
    "host_api": {
      "llm": ["complete"],
      "chat": ["write_message"],
      "window": ["set_title"],
      "agent": {
        "session": { "auto": true },
        "tools": []
      }
    },
    "csp_overrides": {
      "script-src": ["'self'"]
    },
    "state_merge": "last_writer_wins"
  },
  "dev": {
    "fixtures": ["fixtures/*.jsonl"],
    "user_id": 1
  }
}
